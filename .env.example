# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://app:password@localhost:5432/inversiones"

# ============================================================
# BACKEND SERVER
# ============================================================
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ============================================================
# COINGECKO (para precios de crypto)
# Free tier disponible en https://www.coingecko.com/en/api
# Sin API key se puede usar pero con rate limit más bajo
# ============================================================
COINGECKO_API_KEY=

# ============================================================
# IOL — InvertirOnline (para precios de acciones ARG y Cedears)
# Requiere cuenta en https://www.invertironline.com.ar
# ============================================================
IOL_USERNAME=
IOL_PASSWORD=

# ============================================================
# FRONTEND
# ============================================================
VITE_API_BASE_URL=http://localhost:3001/api/v1
